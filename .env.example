# --- Required ---

# BotFather token (https://t.me/BotFather → /newbot)
BOT_TOKEN=

# Your Telegram username (no @) OR numeric user id. Only this user can talk to the bot.
ALLOWED_USERNAME=
# ALLOWED_USER_ID=

# --- Target container (where claude runs) ---

# Name of the container running `claude` CLI. Must be on the same docker network as herald.
TARGET_CONTAINER=claude-code-rc

# User inside the target container to run claude as.
TARGET_USER=cc

# Working directory inside the target container.
TARGET_WORKDIR=/workspace

# --- Behavior ---

# Default model when no per-chat override.
DEFAULT_MODEL=sonnet

# Default approval mode: strict | guided | yolo
# strict = approve every Edit/Write + risky bash
# guided = approve only risky bash (push, deploy, rm -rf, etc.)
# yolo   = approve nothing (default-bypass)
DEFAULT_MODE=guided

# Seconds the approval hook waits for your tap before auto-denying.
APPROVAL_TIMEOUT_SECONDS=300

# Seconds a pending notify token stays valid before the bot forgets it.
# (Used by the Notification hook for interactive tmux-hosted sessions.)
NOTIFY_TTL_SECONDS=3600

# Hard wall-clock kill for a single claude turn (the bot SIGKILLs the child after this).
# Set to 0 to DISABLE the bot's own kill timer entirely (recommended; /stop still works).
CLAUDE_TIMEOUT_MS=0

# Claude Code's API request timeout, passed through to the `docker exec`. Claude Code's
# built-in default is 600000 (10 min); a non-login exec does NOT inherit the target
# container's shell env, so set it here or long single turns die at 10 min. Default 1h.
# CLAUDE_API_TIMEOUT_MS=3600000
# CLAUDE_BASH_DEFAULT_TIMEOUT_MS=300000
# CLAUDE_BASH_MAX_TIMEOUT_MS=3600000

# --- Internal ---

# Port the bot's approval HTTP server listens on (inside docker network only).
APPROVAL_PORT=7788

# Persisted state file path (inside the bot container).
STATE_FILE=/data/state.json
